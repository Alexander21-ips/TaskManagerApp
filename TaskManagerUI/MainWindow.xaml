<Window x:Class="TaskManagerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManagerUI"
        mc:Ignorable="d"
        Title="Менеджер задач" Height="500" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnAdd" Content="Добавить" Width="100" Margin="0,0,5,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Content="Редактировать" Width="100" Margin="0,0,5,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDelete" Content="Удалить" Width="100" Margin="0,0,5,0" Click="BtnDelete_Click"/>
            <Button x:Name="BtnRefresh" Content="Обновить" Width="100" Margin="0,0,5,0" Click="BtnRefresh_Click"/>
            <Button x:Name="BtnSave" Content="Сохранить" Width="100" Margin="0,0,5,0" Click="BtnSave_Click"/>
            <Button x:Name="BtnLoad" Content="Загрузить" Width="100" Click="BtnLoad_Click"/>
        </StackPanel>

        <ListBox x:Name="TasksListBox" Grid.Row="1" SelectionMode="Single"
         Background="White" Foreground="Black">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="14" 
                       Foreground="Black"
                       Margin="5"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Фильтр по статусу:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox x:Name="StatusFilterCombo" Width="120" SelectionChanged="StatusFilterCombo_SelectionChanged">
                <ComboBoxItem Content="Все"/>
                <ComboBoxItem Content="Новая"/>
                <ComboBoxItem Content="ВПроцессе"/>
                <ComboBoxItem Content="Завершена"/>
            </ComboBox>
            <TextBlock Text="   Поиск:" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <TextBox x:Name="SearchBox" Width="150" TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="BtnStat" Content="Статистика" Width="100" Margin="20,0,0,0" Click="BtnStat_Click"/>
        </StackPanel>
    </Grid>
</Window>
